# Copy this file to .env and fill in real values before running docker compose.
# NEVER commit .env to version control - it is in .gitignore.
#
# OWASP A02 (Cryptographic Failures): use strong, randomly-generated passwords.
# Generate one with: openssl rand -base64 32

# PostgreSQL credentials used by docker-compose and the API service.
# Change ALL three values before deploying to any non-local environment.
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me_use_openssl_rand_base64_32
POSTGRES_DB=mcp

# When running the API binary directly (outside Docker), set these so the
# binary can build a properly URL-encoded DSN. In Docker Compose these are
# injected by docker-compose.yml and POSTGRES_HOST defaults to the service name.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# DATABASE_URL is optional: if set it overrides the POSTGRES_* variables above.
# Useful for environments that provide a pre-composed connection string.
# Note: passwords with URL-reserved characters (e.g. "/" from base64) must be
# percent-encoded — prefer the individual POSTGRES_* variables instead.
# DATABASE_URL=postgres://change_me:change_me_use_openssl_rand_base64_32@localhost:5432/mcp

# Port the API HTTP server binds to.
PORT=8080

# OWASP A05 (Security Misconfiguration): Swagger UI is OFF by default.
# Set to "true" only in local development or a dedicated staging environment.
# Never enable in production - it advertises your full API schema.
SWAGGER_ENABLED=false

# OWASP A01 (Broken Access Control): per-IP rate limit in requests per minute.
# Default is 60. Set to 0 to disable (useful for JMeter load-test runs).
# RATE_LIMIT_RPM=60
